# Public access
# Current ECS public IP example. Replace it when deploying to another server.
WEB_PORT=3000
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=/api
API_SERVER_BASE_URL=http://api:4000
CORS_ORIGIN=http://8.163.38.177:3000

# PostgreSQL
POSTGRES_DB=ai_creator_agent
POSTGRES_USER=ai_creator_agent
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_PORT=5432

# Backend runtime
PORT=4000
DATABASE_URL=postgresql://ai_creator_agent:change_this_strong_password@postgres:5432/ai_creator_agent?schema=public

# Text agent provider
AI_TEXT_PROVIDER=apimart
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai/v1
APIMART_MODEL=gpt-5.5

# Image provider and default model
AI_IMAGE_PROVIDER=apimart
APIMART_IMAGE_BASE_URL=https://api.apimart.ai/v1
APIMART_IMAGE_MODEL=gpt-image-2
APIMART_IMAGE_SIZE=1:1

# Optional legacy OpenAI text provider. Only use when AI_TEXT_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
